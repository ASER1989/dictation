.books-page
  min-height 100%
  display flex
  align-items center
  justify-content center
  padding 24px
  box-sizing border-box
  background linear-gradient(145deg, #f4f8ff 0%, #f2fbf5 100%)

  .books-card
    width min(560px, 100%)
    background #fff
    border-radius 14px
    box-shadow 0 12px 24px rgba(0, 0, 0, 0.08)
    padding 28px 24px
    box-sizing border-box
    border 1px solid #eef3f8

  .books-title
    font-size 24px
    font-weight 700
    color #1f3555

  .books-head
    display flex
    justify-content space-between
    align-items center

    .button
      height 34px
      font-size 13px

  .books-subtitle
    margin-top 8px
    color #67809b
    font-size 14px

  .books-field
    margin-top 16px

    .books-label
      margin-bottom 8px
      font-size 14px
      color #38506b

    select
      width 100%
      height 36px
      border 1px solid #d7e2ee
      border-radius 8px
      padding 0 10px
      color #1d2733
      font-size 14px
      outline none
      background #fbfdff

      &:focus
        border-color #2b8be5

      &:disabled
        background #f4f7fa
        color #9aa8b8
        cursor not-allowed

  .books-actions
    margin-top 26px
    display flex
    justify-content flex-end

@media screen and (max-width: 640px)
  .books-page
    padding 16px

    .books-card
      padding 20px 16px

    .books-title
      font-size 20px
